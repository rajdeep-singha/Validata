{
  "name": "datavalid-backend",
  "version": "1.0.0",
  "description": "Transaction data validation platform backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon",
    "dev:all": "concurrently -n API,WORKER -c blue,green \"nodemon\" \"npx ts-node src/worker-entry.ts\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker-entry.js",
    "migrate": "node -e \"require('./dist/db/migrate.js')\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "archiver": "^7.0.1",
    "bullmq": "^5.7.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "dayjs": "^1.11.11",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "ioredis": "^5.3.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.5",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
